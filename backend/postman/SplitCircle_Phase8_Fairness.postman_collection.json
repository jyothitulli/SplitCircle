            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Outsider C\",\n  \"email\": \"fair.outsider.{{$timestamp}}@example.com\",\n  \"password\": \"Password123!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('User C registered (201)', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('tokenC', json.data.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Circle (as A)",
          "request": {
