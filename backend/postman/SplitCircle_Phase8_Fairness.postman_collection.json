              }
            ],
            "url": {
              "raw": "{{baseUrl}}/circles",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "circles"
              ]
            },
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Fairness Test Circle\",\n  \"description\": \"Created by the Phase 8 Postman suite\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Circle created (201)', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('circleId', json.data.circle.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Add Member B to Circle",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{tokenA}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/circles/{{circleId}}/members",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "circles",
                "{{circleId}}",
                "members"
              ]
            },
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userBEmail}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Member added (201)', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Fairness Engine — Happy Path",
      "item": [
        {
          "name": "Create Expense (A pays 1200, split equally with B)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{tokenA}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/circles/{{circleId}}/expenses",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "circles",
                "{{circleId}}",
                "expenses"
              ]
            },
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Groceries\",\n  \"amount\": 1200,\n  \"splitMethod\": \"EQUAL\",\n  \"paidById\": \"{{userAId}}\",\n  \"participants\": [\n    {\n      \"userId\": \"{{userAId}}\"\n    },\n    {\n      \"userId\": \"{{userBId}}\"\n    }\n  ]\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Expense created (201)', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('expenseId', json.data.expense.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Chore for A (due today)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{tokenA}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/circles/{{circleId}}/chores",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "circles",
                "{{circleId}}",
                "chores"
              ]
            },
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Take out the trash\",\n  \"description\": \"Weekly bins\",\n  \"isRecurring\": false,\n  \"assignedUserId\": \"{{userAId}}\",\n  \"dueDate\": \"{{$isoTimestamp}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Chore A created (201)', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('choreAId', json.data.chore.id);",
                  "pm.collectionVariables.set('assignmentAId', json.data.chore.assignments[0].id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Chore for B (due today)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{tokenA}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/circles/{{circleId}}/chores",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "circles",
                "{{circleId}}",
                "chores"
              ]
            },
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Wash the dishes\",\n  \"description\": \"Daily dishes\",\n  \"isRecurring\": false,\n  \"assignedUserId\": \"{{userBId}}\",\n  \"dueDate\": \"{{$isoTimestamp}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Chore B created (201)', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('choreBId', json.data.chore.id);",
                  "pm.collectionVariables.set('assignmentBId', json.data.chore.assignments[0].id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Complete A's Chore Assignment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{tokenA}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/chores/assignments/{{assignmentAId}}/complete",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "chores",
                "assignments",
                "{{assignmentAId}}",
                "complete"
              ]
            },
            "description": ""
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Assignment completed (200)', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Calculate Fairness Scores (B has not paid or finished chore yet)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{tokenA}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/circles/{{circleId}}/fairness/calculate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "circles",
                "{{circleId}}",
                "fairness",
                "calculate"
              ]
            },
            "description": ""
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const scores = pm.response.json().data.scores;",
                  "pm.test('Scores returned for both members', () => pm.expect(scores.length).to.eql(2));",
                  "pm.test('Sorted descending by overallScore', () => {",
                  "  for (let i = 1; i < scores.length; i++) {",
                  "    pm.expect(Number(scores[i - 1].overallScore)).to.be.at.least(Number(scores[i].overallScore));",
                  "  }",
                  "});",
                  "const a = scores.find((s) => s.userId === pm.collectionVariables.get('userAId'));",
                  "const b = scores.find((s) => s.userId === pm.collectionVariables.get('userBId'));",
                  "pm.test('A (paid in full, chore done) scores 100 overall', () => pm.expect(Number(a.overallScore)).to.eql(100));",
                  "pm.test('B (owes share, chore pending) scores below 100', () => pm.expect(Number(b.overallScore)).to.be.below(100));",
                  "pm.test('Weighted formula holds for A: 0.5*expense + 0.3*chore + 0.2*participation', () => {",
                  "  const expected = Number(a.expenseScore) * 0.5 + Number(a.choreScore) * 0.3 + Number(a.participationScore) * 0.2;",
                  "  pm.expect(Number(a.overallScore)).to.be.closeTo(expected, 0.01);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Fairness Leaderboard (as B — any member can read)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{tokenB}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/circles/{{circleId}}/fairness",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "circles",
                "{{circleId}}",
                "fairness"
              ]
            },
            "description": ""
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const leaderboard = pm.response.json().data.leaderboard;",
                  "pm.test('Leaderboard sorted descending', () => {",
                  "  for (let i = 1; i < leaderboard.length; i++) {",
                  "    pm.expect(Number(leaderboard[i - 1].overallScore)).to.be.at.least(Number(leaderboard[i].overallScore));",
                  "  }",
                  "});",
                  "pm.test('Leaderboard reflects the last calculate call (persisted, not recomputed on GET)', () => {",
                  "  pm.expect(leaderboard.length).to.eql(2);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Complete B's Chore Assignment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{tokenB}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/chores/assignments/{{assignmentBId}}/complete",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "chores",
                "assignments",
                "{{assignmentBId}}",
                "complete"
              ]
            },
            "description": ""
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Assignment completed (200)', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Optimize Settlements (generates B -> A debt)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{tokenA}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/circles/{{circleId}}/settlements/optimize",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "circles",
                "{{circleId}}",
                "settlements",
                "optimize"
              ]
            },
            "description": ""
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const settlements = pm.response.json().data.settlements;",
                  "const sBtoA = settlements.find((s) => s.fromUserId === pm.collectionVariables.get('userBId'));",
                  "pm.test('A settlement from B to A exists', () => pm.expect(sBtoA).to.not.be.undefined);",
                  "if (sBtoA) pm.collectionVariables.set('settlementId', sBtoA.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Pay Settlement (B settles up with A)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{tokenB}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/settlements/{{settlementId}}/pay",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "settlements",
                "{{settlementId}}",
                "pay"
              ]
            },
            "description": ""
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Settlement paid (200)', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Recalculate Fairness Scores (both fully settled and caught up)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{tokenA}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/circles/{{circleId}}/fairness/calculate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "circles",
                "{{circleId}}",
                "fairness",
                "calculate"
              ]
            },
            "description": ""
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const scores = pm.response.json().data.scores;",
                  "const a = scores.find((s) => s.userId === pm.collectionVariables.get('userAId'));",
                  "const b = scores.find((s) => s.userId === pm.collectionVariables.get('userBId'));",
                  "pm.test('A still scores 100 overall', () => pm.expect(Number(a.overallScore)).to.eql(100));",
                  "pm.test('B now scores 100 overall after settling and finishing chores', () => pm.expect(Number(b.overallScore)).to.eql(100));"
                ]
              }
            }
          ]
        }
      ]
    },
