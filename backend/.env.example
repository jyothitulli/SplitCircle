# Server
# Must match frontend/vite.config.js proxy target and frontend/.env's VITE_API_URL
PORT=4000
NODE_ENV=development

# CORS (frontend dev URL)
CORS_ORIGIN=http://localhost:5173

# Database
# Format: postgresql://<user>:<password>@<host>:<port>/<database_name>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/splitcircle

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Phase 9A — Cloudinary (receipt image storage)
# Sign up free at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=Root
CLOUDINARY_API_KEY=655277971545297
CLOUDINARY_API_SECRET=AjO-Ar1z05irVdCQ3GkPZnZI7Ns

# Phase 9B + 9C — Google Gemini API
# Get key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
